---
---

<button type="button" class="theme-toggle" aria-label="Toggle dark mode" data-theme-toggle>
  <span class="theme-toggle__sun">☀</span>
  <span class="theme-toggle__moon">☾</span>
</button>

<script>
  const key = "theme-preference";
  const root = document.documentElement;

  function apply(theme: "light" | "dark") {
    root.dataset.theme = theme;
    localStorage.setItem(key, theme);
  }

  function init() {
    const stored = localStorage.getItem(key) as "light" | "dark" | null;
    if (stored) apply(stored);
    else if (window.matchMedia("(prefers-color-scheme: dark)").matches) apply("dark");
    else apply("light");
  }

  init();

  document.querySelectorAll("[data-theme-toggle]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const next = root.dataset.theme === "dark" ? "light" : "dark";
      apply(next);
    });
  });
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface-2);
    color: var(--text);
    cursor: pointer;
    font-size: 1.1rem;
    line-height: 1;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .theme-toggle:hover {
    background: var(--surface-3);
  }

  :global([data-theme="light"]) .theme-toggle__moon {
    display: none;
  }

  :global([data-theme="dark"]) .theme-toggle__sun {
    display: none;
  }
</style>
